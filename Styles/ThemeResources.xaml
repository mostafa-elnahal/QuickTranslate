<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Color Palette -->
    <Color x:Key="WindowBackgroundColor">#202020</Color>
    <Color x:Key="SurfaceColor">#2D2D30</Color>
    <Color x:Key="BorderColor">#3E3E42</Color>
    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="TextPrimaryColor">#F1F1F1</Color>
    <Color x:Key="TextSecondaryColor">#AAAAAA</Color>
    <Color x:Key="ErrorColor">#FF4444</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

    <!-- Typography -->
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeNormal">12</sys:Double>
    <sys:Double x:Key="FontSizeLarge">14</sys:Double>
    <sys:Double x:Key="FontSizeHeader">16</sys:Double>

    <!-- Base Styles -->
    <!-- Base Styles -->
    <Style x:Key="IconPathStyle" TargetType="Path">
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Control}}"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <!-- Margin and Cursor are now handled by the parent Button -->
    </Style>

    <Style x:Key="WindowHeaderButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3E3E42"/> <!-- Hover Background -->
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/> <!-- Hover Foreground (Icon Color) -->
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                 <Setter Property="Background" Value="#555555"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="WindowHeaderCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowHeaderButtonStyle}">
        <Style.Triggers>
             <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

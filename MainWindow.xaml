<Window x:Class="QuickTranslate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTranslate"
        xmlns:converters="clr-namespace:QuickTranslate.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="QuickTranslate"
        Width="600"
        MinWidth="300" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Visibility="{Binding WindowVisibility}"
        SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Style>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection"/>
    </Window.Resources>
    
    <Border Background="{StaticResource WindowBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="4" Opacity="0.4" Direction="270" RenderingBias="Performance"/>
        </Border.Effect>
        
        <!-- Main Container -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header: Fixed, not scrollable (also serves as drag area) -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0" DataContext="{Binding CurrentTranslation}">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0">
                    <Run Text="{Binding SourceLanguage, Mode=OneWay}" FontWeight="SemiBold"/> 
                    <Run Text=" ➔ " Foreground="{StaticResource TextSecondaryBrush}"/> 
                    <Run Text="{Binding TargetLanguage, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  "/>
                    <Run Text="{Binding ProviderName, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
                
                <!-- Header Icons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                     <!-- Star (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Save to Favorites">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                    </Button>
                    
                     <!-- Copy -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Copy Translation">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                    </Button>
                    
                     <!-- Speaker (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Listen">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z"/>
                    </Button>
                    
                     <!-- Close Button -->
                    <Button Style="{StaticResource WindowHeaderCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                              Height="10" Width="10"/>
                    </Button>
                </StackPanel>
            </DockPanel>
            
            <!-- Scrollable Content Area -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource SlimScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding CurrentTranslation}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Main Translated Word -->
                    <TextBox Text="{Binding MainTranslation, Mode=OneWay}" 
                             Foreground="{StaticResource TextPrimaryBrush}" 
                             FontSize="18" 
                             FontWeight="Medium"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             IsInactiveSelectionHighlightEnabled="True"
                             FlowDirection="{Binding IsRtl, Converter={StaticResource BoolToFlowDirection}}"
                             Margin="12,0,12,8"/>

                    <!-- Dictionary Entries -->
                    <ItemsControl ItemsSource="{Binding DictionaryEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="12,0,12,8">
                                    <TextBlock Text="{Binding PartOfSpeech}" 
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               FontStyle="Italic"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,0,4"/>
                                    
                                    <!-- Definitions -->
                                    <ItemsControl ItemsSource="{Binding Definitions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Unified TextBlock for MainTerm + Synonyms -->
                                                <TextBlock HorizontalAlignment="Right" Margin="0,3">
                                                    <Run Text="{Binding SynonymsText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding MainTerm}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeNormal}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer / Providers Bar (Auto-Hide) -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Providers}" Margin="0" VerticalAlignment="Bottom">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Visibility" Value="Hidden"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Hidden}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0" Padding="6,3" Cursor="Hand" 
                                Background="{StaticResource SurfaceBrush}" 
                                BorderThickness="0,2,0,0"
                                BorderBrush="{Binding BrandColor}"
                                CornerRadius="0"
                                MouseLeftButtonDown="Provider_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#383838"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Name}" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       FontSize="{StaticResource FontSizeSmall}" 
                                       TextTrimming="CharacterEllipsis" 
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>

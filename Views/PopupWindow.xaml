<Window x:Class="QuickTranslate.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTranslate"
        xmlns:converters="clr-namespace:QuickTranslate.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="QuickTranslate"
        Width="600"
        MinWidth="300" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Visibility="{Binding WindowVisibility}"
        SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Style>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </Window.Resources>
    
    <Border Background="{StaticResource WindowBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="4" Opacity="0.4" Direction="270" RenderingBias="Performance"/>
        </Border.Effect>
        
        <!-- Main Container -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header: Fixed, not scrollable (also serves as drag area) -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0" DataContext="{Binding CurrentTranslation}">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0">
                    <Run Text="{Binding SourceLanguage, Mode=OneWay}" FontWeight="SemiBold"/> 
                    <Run Text=" ➔ " Foreground="{StaticResource TextSecondaryBrush}"/> 
                    <Run Text="{Binding TargetLanguage, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  "/>
                    <Run Text="{Binding ProviderName, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
                
                <!-- Header Icons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                     <!-- Star (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Save to Favorites">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                    </Button>
                    
                     <!-- Copy -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Copy Translation">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                    </Button>
                    
                     <!-- Speaker (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Listen">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z"/>
                    </Button>
                    
                     <!-- Close Button -->
                    <Button Style="{StaticResource WindowHeaderCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                              Height="10" Width="10"/>
                    </Button>
                </StackPanel>
            </DockPanel>
            
            <!-- Scrollable Content Area -->
            <ScrollViewer x:Name="ContentScrollViewer"
                          Grid.Row="1" 
                          Style="{StaticResource SlimScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding CurrentTranslation}" Margin="0,0,0,32">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Main Translated Word -->
                    <TextBox Text="{Binding MainTranslation, Mode=OneWay}" 
                    		 PreviewMouseLeftButtonDown="TranslationBox_PreviewMouseLeftButtonDown"
                             Foreground="{StaticResource TextPrimaryBrush}" 
                             FontSize="{Binding DataContext.TranslationFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                             FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                             FontWeight="{Binding DataContext.TranslationFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             IsInactiveSelectionHighlightEnabled="True"
                             FlowDirection="{Binding IsRtl, Converter={StaticResource BoolToFlowDirection}}"
                             Margin="12,0,12,8"/>

                    <!-- Dictionary Entries -->
                    <ItemsControl ItemsSource="{Binding DictionaryEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="12,4,12,8">
                                    <StackPanel.Resources>
                                        <converters:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection"/>
                                    </StackPanel.Resources>

                                    <!-- POS Header -->
                                    <Border HorizontalAlignment="Left" 
                                            Background="#252525" 
                                            CornerRadius="4" 
                                            Padding="6,2" 
                                            Margin="0,0,0,6">
                                        <TextBlock Text="{Binding PartOfSpeech}" 
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontWeight="SemiBold"
                                                   FontStyle="Italic"/>
                                    </Border>
                                    
                                    <!-- Definitions List -->
                                    <ItemsControl ItemsSource="{Binding Definitions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Dynamic Template based on Parent EntryType -->
                                                <ContentControl Content="{Binding}">
                                                    <ContentControl.Style>
                                                        <Style TargetType="ContentControl">
                                                            <Setter Property="ContentTemplate">
                                                                <Setter.Value>
                                                                    <!-- Default / Translation Template -->
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            
                                                                            <!-- Synonyms (Source Language - LTR/RTL Source) -->
                                                                            <TextBlock Grid.Column="0" 
                                                                                       Text="{Binding SynonymsText}" 
                                                                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                                                                       FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       VerticalAlignment="Center"
                                                                                       TextWrapping="Wrap"
                                                                                       FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"/>
                                                                            
                                                                            <!-- Translated Word (Target Language - LTR/RTL Target) -->
                                                                            <TextBlock Grid.Column="1" 
                                                                                       Text="{Binding MainTerm}" 
                                                                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                                                                       FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="8,0,0,0"
                                                                                       FlowDirection="{Binding DataContext.IsRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            
                                                            <Style.Triggers>
                                                                <!-- Definition Template -->
                                                                <DataTrigger Binding="{Binding DataContext.EntryType, RelativeSource={RelativeSource AncestorType=StackPanel, AncestorLevel=2}}" Value="Definition">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <StackPanel Margin="0,4" 
                                                                                            FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"
                                                                                            Visibility="{Binding IsDetailsExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                                                    <BulletDecorator>
                                                                                        <BulletDecorator.Bullet>
                                                                                            <Ellipse Height="4" Width="4" Fill="{StaticResource TextSecondaryBrush}" Margin="0,7,8,0"/>
                                                                                        </BulletDecorator.Bullet>
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding MainTerm}" 
                                                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                                                       FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       TextWrapping="Wrap"/>
                                                                                            <TextBlock Text="{Binding SynonymsText}" 
                                                                                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                                                                                       FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontStyle="Italic"
                                                                                                       Margin="0,2,0,0"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Visibility="{Binding SynonymsText, Converter={StaticResource StringToVis}}"/>
                                                                                        </StackPanel>
                                                                                    </BulletDecorator>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                
                                                                <!-- Example Template -->
                                                                <DataTrigger Binding="{Binding DataContext.EntryType, RelativeSource={RelativeSource AncestorType=StackPanel, AncestorLevel=2}}" Value="Example">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding MainTerm}" 
                                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                                           FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           FontStyle="Italic"
                                                                                           Margin="8,2"
                                                                                           TextWrapping="Wrap"
                                                                                           FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"
                                                                                           Visibility="{Binding IsDetailsExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ContentControl.Style>
                                                </ContentControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Toggle Button for Details -->
                    <ToggleButton IsChecked="{Binding IsDetailsExpanded, RelativeSource={RelativeSource AncestorType=Window}}"
                                  HorizontalAlignment="Center"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Margin="0,0,0,12"
                                  Cursor="Hand">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Padding="8,4">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock x:Name="Text" Text="Show more details" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center"/>
                                                        <Path x:Name="Icon" 
                                                              Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" 
                                                              Fill="{StaticResource TextSecondaryBrush}" 
                                                              Margin="6,1,0,0" 
                                                              VerticalAlignment="Center"
                                                              Height="8"
                                                              Width="8"
                                                              Stretch="Uniform"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Text" Property="Text" Value="Show less"/>
                                                        <Setter TargetName="Icon" Property="Data" Value="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Text" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        <Setter TargetName="Icon" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!-- Only Visible if we have Rich Details (Def/Example) -->
                                <Style.Triggers>
                                     <DataTrigger Binding="{Binding HasRichDetails}" Value="False">
                                         <Setter Property="Visibility" Value="Collapsed"/>
                                     </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer / Providers Bar (Auto-Hide) -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Providers}" Margin="0" VerticalAlignment="Bottom">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Visibility" Value="Hidden"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Hidden}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Click="Provider_Click" Cursor="Hand" Style="{x:Null}" Padding="0" BorderThickness="0" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Margin="0" 
                                            Padding="6,3" 
                                            Background="{StaticResource SurfaceBrush}" 
                                            BorderThickness="0,2,0,0"
                                            BorderBrush="{Binding BrandColor}"
                                            CornerRadius="0">
                                        <TextBlock Text="{Binding Name}" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="{StaticResource FontSizeSmall}" 
                                                   TextTrimming="CharacterEllipsis" 
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource BorderBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                        </DataTrigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#151515"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>

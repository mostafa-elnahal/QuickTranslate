<Window x:Class="QuickTranslate.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTranslate"
        xmlns:converters="clr-namespace:QuickTranslate.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="QuickTranslate"
        Width="600"
        MinWidth="300" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Visibility="{Binding WindowVisibility}"
        SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Style>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </Window.Resources>
    
    <Border Background="{StaticResource WindowBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8"
            ClipToBounds="True"
            Padding="0">

        
        <!-- Main Container -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header: Fixed, not scrollable (also serves as drag area) -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0" DataContext="{Binding CurrentTranslation}">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0">
                    <Run Text="{Binding SourceLanguage, Mode=OneWay}" FontWeight="SemiBold"/> 
                    <Run Text=" ➔ " Foreground="{StaticResource TextSecondaryBrush}"/> 
                    <Run Text="{Binding TargetLanguage, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  "/>
                    <Run Text="{Binding ProviderName, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
                
                <!-- Header Icons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                     <!-- Star (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Save to Favorites">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                    </Button>
                    
                     <!-- Copy -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Copy Translation">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                    </Button>
                    
                     <!-- Speaker (Placeholder) -->
                    <Button Style="{StaticResource WindowHeaderButtonStyle}" ToolTip="Listen">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z"/>
                    </Button>
                    
                     <!-- Close Button -->
                    <Button Style="{StaticResource WindowHeaderCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                              Height="10" Width="10"/>
                    </Button>
                </StackPanel>
            </DockPanel>
            
            <!-- Scrollable Content Area -->
            <ScrollViewer x:Name="ContentScrollViewer"
                          Grid.Row="1" 
                          Style="{StaticResource SlimScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding CurrentTranslation}" Margin="0,0,0,32">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Main Translated Word -->
                    <TextBox Text="{Binding MainTranslation, Mode=OneWay}" 
                    		 PreviewMouseLeftButtonDown="TranslationBox_PreviewMouseLeftButtonDown"
                             Foreground="{StaticResource TextPrimaryBrush}" 
                             FontSize="{Binding DataContext.TranslationFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                             FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                             FontWeight="Bold"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             IsInactiveSelectionHighlightEnabled="True"
                             FlowDirection="{Binding IsRtl, Converter={StaticResource BoolToFlowDirection}}"
                             Margin="12,0,12,8"/>

                    <!-- Dictionary Entries -->
                    <ItemsControl ItemsSource="{Binding DictionaryEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="12,4,12,8">
                                    <StackPanel.Resources>
                                        <converters:BoolToFlowDirectionConverter x:Key="BoolToFlowDirection"/>
                                    </StackPanel.Resources>

                                    <!-- Clickable Section Header with Chevron -->
                                    <Border Background="Transparent" 
                                            Cursor="Hand"
                                            MouseLeftButtonDown="SectionHeader_Click"
                                            Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Chevron Indicator -->
                                            <Path Data="M0.5,0.5 L4.5,4.5 L0.5,8.5"
                                                  Stroke="{StaticResource TextSecondaryBrush}"
                                                  StrokeThickness="{Binding DataContext.ChevronStrokeThickness, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Fill="Transparent"
                                                  Width="{Binding DataContext.ChevronWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Height="{Binding DataContext.ChevronHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,4,0"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="90"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                            <!-- Header Badge (Minimal Text) -->
                                            <TextBlock Text="{Binding HeaderText}" 
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontWeight="Normal"
                                                       FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Margin="0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Definitions List (Collapsible) -->
                                    <ItemsControl ItemsSource="{Binding Definitions}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Dynamic Template based on Parent EntryType -->
                                                <ContentControl Content="{Binding}">
                                                    <ContentControl.Style>
                                                        <Style TargetType="ContentControl">
                                                            <Setter Property="ContentTemplate">
                                                                <Setter.Value>
                                                                    <!-- Default / Translation Template -->
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            
                                                                            <!-- Synonyms (Source Language - LTR/RTL Source) -->
                                                                            <TextBlock Grid.Column="0" 
                                                                                       Text="{Binding SynonymsText}" 
                                                                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                                                                       FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       VerticalAlignment="Center"
                                                                                       TextWrapping="Wrap"
                                                                                       FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"/>
                                                                            
                                                                            <!-- Translated Word (Target Language - LTR/RTL Target) -->
                                                                            <TextBlock Grid.Column="1" 
                                                                                       Text="{Binding MainTerm}" 
                                                                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                                                                       FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="8,0,0,0"
                                                                                       FlowDirection="{Binding DataContext.IsRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            
                                                            <Style.Triggers>
                                                                <!-- Definition Template -->
                                                                <DataTrigger Binding="{Binding DataContext.EntryType, RelativeSource={RelativeSource AncestorType=StackPanel, AncestorLevel=2}}" Value="Definition">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <StackPanel Margin="0,4" 
                                                                                            FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}">
                                                                                    <BulletDecorator>
                                                                                        <BulletDecorator.Bullet>
                                                                                            <Ellipse Height="4" Width="4" Fill="{StaticResource TextSecondaryBrush}" Margin="0,7,8,0"/>
                                                                                        </BulletDecorator.Bullet>
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding MainTerm}" 
                                                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                                                       FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       TextWrapping="Wrap"/>
                                                                                            <TextBlock Text="{Binding SynonymsText}" 
                                                                                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                                                                                       FontSize="{Binding DataContext.DictionarySmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                       FontStyle="Italic"
                                                                                                       Margin="0,2,0,0"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Visibility="{Binding SynonymsText, Converter={StaticResource StringToVis}}"/>
                                                                                        </StackPanel>
                                                                                    </BulletDecorator>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                
                                                                <!-- Example Template -->
                                                                <DataTrigger Binding="{Binding DataContext.EntryType, RelativeSource={RelativeSource AncestorType=StackPanel, AncestorLevel=2}}" Value="Example">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding MainTerm}" 
                                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                                           FontSize="{Binding DataContext.DictionaryTermFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           FontFamily="{Binding DataContext.TranslationFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           FontStyle="Italic"
                                                                                           Margin="8,2"
                                                                                           TextWrapping="Wrap"
                                                                                           FlowDirection="{Binding DataContext.IsSourceRtl, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToFlowDirection}}"/>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ContentControl.Style>
                                                </ContentControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <!-- Section Divider -->
                                    <Border Height="1" 
                                            Background="{StaticResource BorderBrush}" 
                                            Margin="30,8,30,0" 
                                            Opacity="0.4"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer / Providers Bar (Auto-Hide) -->
            <Border x:Name="FooterBorder" Grid.Row="1" VerticalAlignment="Bottom" Margin="0" CornerRadius="0,0,8,8" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black" CornerRadius="0,0,8,8"
                                    Width="{Binding ActualWidth, ElementName=FooterBorder}"
                                    Height="{Binding ActualHeight, ElementName=FooterBorder}"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Visibility" Value="Hidden"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Hidden}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Click="Provider_Click" Cursor="Hand" Style="{x:Null}" Padding="0" BorderThickness="0" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Margin="0" 
                                            Padding="6,3" 
                                            Background="{StaticResource SurfaceBrush}" 
                                            BorderThickness="0,2,0,0"
                                            BorderBrush="{Binding BrandColor}"
                                            CornerRadius="0">
                                        <TextBlock Text="{Binding Name}" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="{StaticResource FontSizeSmall}" 
                                                   TextTrimming="CharacterEllipsis" 
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource BorderBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                        </DataTrigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#151515"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
    </Border>
</Window>

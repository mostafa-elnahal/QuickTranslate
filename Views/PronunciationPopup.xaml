<Window x:Class="QuickTranslate.Views.PronunciationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:QuickTranslate.Converters"
        mc:Ignorable="d"
        Title="QuickTranslate - Pronunciation"
        Icon="pack://application:,,,/Assets/ico-v2.ico"
        MinWidth="300" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}"
        SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <c:TimeSpanToDoubleConverter x:Key="TimeSpanToDoubleConverter"/>
        
        <!-- Modern Slider Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" VerticalAlignment="Center" Height="20">
                            <!-- Track Background (The tube) -->
                            <Border x:Name="TrackBackground"
                                    Height="4"
                                    CornerRadius="2"
                                    Background="{StaticResource BorderBrush}"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Parts -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Style>
                                            <Style TargetType="RepeatButton">
                                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Focusable" Value="False"/>
                                                <Setter Property="IsTabStop" Value="False"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Height="4"
                                                                    CornerRadius="2"
                                                                    Background="{TemplateBinding Background}"
                                                                    VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </RepeatButton.Style>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="12" Height="12" VerticalAlignment="Center" Focusable="False" OverridesDefaultStyle="True">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="White">
                                                         <Border.Effect>
                                                             <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.3" Color="Black"/>
                                                         </Border.Effect>
                                                    </Border>
                                                    <Ellipse Width="12" Height="12" Fill="White"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Style>
                                            <Style TargetType="RepeatButton">
                                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Focusable" Value="False"/>
                                                <Setter Property="IsTabStop" Value="False"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Background="{TemplateBinding Background}" Height="4" VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </RepeatButton.Style>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TrackBackground" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.5"/>
                            </Trigger>
                             <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Style>

    <Border Background="{StaticResource WindowBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8"
            ClipToBounds="True"
            Padding="0">

        <!-- Main Container -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Scrollable Content -->
                <RowDefinition Height="Auto"/> <!-- Fixed Footer (Controls + Status) -->
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                         <!-- Mimic Title Style -->
                    </Style>
                </DockPanel.Style>
                <TextBlock VerticalAlignment="Center" 
                           FontSize="{StaticResource FontSizeSmall}" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="12,0,0,0"
                           Text="Pronunciation"
                           FontWeight="SemiBold"/>
                
                <!-- Close Button -->
                <Button DockPanel.Dock="Right" Style="{StaticResource WindowHeaderCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                    <Path Style="{StaticResource IconPathStyle}"
                          Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                          Height="10" Width="10"/>
                </Button>
            </DockPanel>
            
            <!-- Scrollable Content Area -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,0"
                          Padding="20,16,20,16">
                <StackPanel>
                    
                    <!-- Original Word (large, centered) -->
                    <TextBlock Text="{Binding OriginalText}"
                               FontSize="{Binding FontSize}"
                               FontFamily="{Binding FontFamily}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Divider -->
                    <Border Height="1" 
                            Background="{StaticResource BorderBrush}" 
                            Margin="0,0,0,16"
                            Opacity="0.5"/>

                    <!-- "Sounds like" Label -->
                    <TextBlock Text="Sounds like" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSingleWord}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Syllables Display (centered, with separators) -->
                    <ItemsControl ItemsSource="{Binding Syllables}" HorizontalAlignment="Center">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSingleWord}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Text}" 
                                               FontSize="{Binding DataContext.PhoneticsFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <!-- Highlight Stressed Syllable -->
                                                    <DataTrigger Binding="{Binding IsStressed}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    
                                                    <!-- Highlight Active Syllable -->
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Separator dot (hidden for last item via converter or always show) -->
                                    <TextBlock Text=" · " 
                                               FontSize="{Binding DataContext.PhoneticsFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- IPA Phonetics (if available) -->
                    <TextBlock Text="{Binding PhoneticsDisplay}"
                               FontSize="{StaticResource FontSizeSmall}"
                               FontStyle="Italic"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSingleWord}" Value="True"/>
                                            <Condition Binding="{Binding HasPhonetics}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Status/Loading moved to Status Bar -->
                </StackPanel>
            </ScrollViewer>

            <!-- Fixed Footer (Controls) -->
            <Border Grid.Row="2" 
                    Background="{StaticResource WindowBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Progress -->
                        <RowDefinition Height="Auto"/> <!-- Controls -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Progress -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Current Time -->
                        <TextBlock Text="{Binding CurrentPosition, StringFormat={}{0:mm\\:ss}}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <!-- Slider -->
                        <Slider Grid.Column="1"
                                Style="{StaticResource ModernSliderStyle}"
                                Value="{Binding CurrentPosition, Converter={StaticResource TimeSpanToDoubleConverter}, Mode=TwoWay}"
                                Maximum="{Binding TotalDuration, Converter={StaticResource TimeSpanToDoubleConverter}, Mode=OneWay}"
                                Thumb.DragStarted="Slider_DragStarted"
                                Thumb.DragCompleted="Slider_DragCompleted"
                                ValueChanged="Slider_ValueChanged"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                Cursor="Hand"/>
                                
                        <!-- Total Duration -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding TotalDuration, StringFormat={}{0:mm\\:ss}}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Row 1: Controls -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Status & Language -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                            <!-- Language Indicator -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="&#xE7F4;" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="10" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding LanguageName}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <!-- Status Code / Loading -->
                            <Grid>
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="10"
                                           Foreground="Red"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                                <StackPanel Orientation="Horizontal" 
                                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Loading..."
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Center: Playback Controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                             <!-- Play/PauseButton (Prominent) -->
                            <Button x:Name="PlayButton"
                                    Command="{Binding DataContext.PlayPauseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Width="42" Height="42"
                                    Style="{x:Null}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                    ToolTip="Play/Pause">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PlayBorder"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="21">
                                            <Grid>
                                                <!-- Play Icon -->
                                                <Path x:Name="PlayIcon"
                                                      Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                                      Fill="White"
                                                      Stretch="Uniform"
                                                      Width="14" Height="14"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,0,0"
                                                      Visibility="{Binding DataContext.IsPlaying, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}"/>
                                                <!-- Pause Icon -->
                                                <Path x:Name="PauseIcon"
                                                      Data="M14,19H18V5H14M6,19H10V5H6V19Z"
                                                      Fill="White"
                                                      Stretch="Uniform"
                                                      Width="12" Height="12"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding DataContext.IsPlaying, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PlayBorder" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="PlayBorder" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="PlayBorder" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Right: Speed & Restart -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- Restart (Small) -->
                             <Button Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Width="24" Height="24"
                                    Style="{x:Null}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Restart"
                                    Margin="0,0,12,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.86,17.53 19.71,14H17.58C16.83,16.35 14.63,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform"
                                              Width="14" Height="14"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Speed Toggle Text -->
                             <ToggleButton IsChecked="{Binding IsSlowMode}"
                                          Style="{x:Null}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          ToolTip="Toggle speed (0.5x / 1.0x)">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="4,2">
                                            <TextBlock x:Name="SpeedText"
                                                       Text="1.0x"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="SpeedText" Property="Text" Value="0.5x"/>
                                                <Setter TargetName="SpeedText" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
                    
            <!-- Hidden MediaElement for audio playback -->
            <MediaElement x:Name="AudioPlayer"
                          Grid.Row="2"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          MediaOpened="AudioPlayer_MediaOpened"
                          MediaEnded="AudioPlayer_MediaEnded"
                          MediaFailed="AudioPlayer_MediaFailed"
                          Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>

<Window x:Class="QuickTranslate.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="600"
        Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource WindowBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/> <!-- Compact Title Bar -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/> <!-- Compact Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock Text="Options" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="{StaticResource FontSizeLarge}"
                               VerticalAlignment="Center" 
                               Margin="12,0,0,0"/>
                    <Button Style="{StaticResource WindowHeaderCloseButtonStyle}" 
                            Click="CloseButton_Click" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Close">
                        <Path Style="{StaticResource IconPathStyle}"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                              Height="10" Width="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Background="#252526">
                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,4"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" 
                                                    Background="Transparent" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <!-- Right Content Area -->
                <ScrollViewer Grid.Column="1" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0">
                    <Grid Margin="12,12,12,0">
                    
                    <!-- Basics Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=Basics}">
                        <GroupBox Header="General" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2" 
                                          Content="Start with Windows" 
                                          IsChecked="{Binding StartWithWindows}"
                                          Style="{StaticResource SettingsCheckBoxStyle}"
                                          Margin="0,4,0,8"/>
                                
                                <TextBlock Grid.Row="1" Text="Window opacity:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Slider Grid.Row="1" Grid.Column="1" 
                                        Minimum="0.3" Maximum="1.0" 
                                        Value="{Binding WindowOpacity}"
                                        VerticalAlignment="Center"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="True"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Hotkeys Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=Hotkeys}">
                        <GroupBox Header="Shortcuts" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <!-- Action Name -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="Translate selection" 
                                           VerticalAlignment="Center" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                
                                <!-- Clickable Hotkey Cell -->
                                <Button Grid.Row="0" Grid.Column="1" 
                                        Content="{Binding Hotkey}"
                                        Click="EditHotkey_Click"
                                        MinWidth="80"
                                        Padding="8,4"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="Click to change hotkey">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WindowHeaderButtonStyle}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Pronunciation Action -->
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="Pronounce word" 
                                           VerticalAlignment="Center" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                <!-- Pronunciation Hotkey Button -->
                                <Button Grid.Row="1" Grid.Column="1" 
                                        Content="{Binding PronunciationHotkey}"
                                        Click="EditPronunciationHotkey_Click"
                                        MinWidth="80"
                                        Padding="8,4"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="Click to change hotkey">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WindowHeaderButtonStyle}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Languages Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=Languages}">
                        <GroupBox Header="Auto-detect languages" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="Source language:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedValue="{Binding DefaultSourceLanguage}"
                                          SelectedValuePath="Code"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,2"/>

                                <TextBlock Grid.Row="1" Text="Target language:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedValue="{Binding DefaultTargetLanguage}"
                                          SelectedValuePath="Code"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,2"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="Services" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Default provider:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableProviders}"
                                          SelectedItem="{Binding DefaultProvider}"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Appearance Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=Appearance}">
                        <GroupBox Header="Appearance" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Font size:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource SettingsTextBoxStyle}"
                                             VerticalAlignment="Center"
                                             Width="50"
                                             HorizontalContentAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center" Margin="4,0,0,0">
                                        <Button Content="▲" Click="IncreaseFontSize_Click" 
                                                Style="{StaticResource WindowHeaderButtonStyle}"
                                                Padding="4,0" MinHeight="12" FontSize="8"/>
                                        <Button Content="▼" Click="DecreaseFontSize_Click" 
                                                Style="{StaticResource WindowHeaderButtonStyle}"
                                                Padding="4,0" MinHeight="12" FontSize="8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="Font Style" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="Font family:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableFontFamilies}"
                                          SelectedItem="{Binding FontFamily}"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="Font weight:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableFontWeights}"
                                          SelectedItem="{Binding FontWeight}"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Pronunciation Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=Pronunciation}">
                         <GroupBox Header="Provider Settings" Style="{StaticResource SettingsGroupBoxStyle}">
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="Provider:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          ItemsSource="{Binding AvailablePronunciationProviders}"
                                          SelectedItem="{Binding PronunciationProvider}"
                                          Style="{StaticResource SettingsComboBoxStyle}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="Gemini API Key:" 
                                           VerticalAlignment="Center" 
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsEnabled="{Binding IsApiKeyInputEnabled}"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" 
                                             x:Name="GeminiApiKeyBox"
                                             PasswordChar="•"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             Height="26"
                                             PasswordChanged="GeminiApiKeyBox_PasswordChanged"
                                             ToolTip="Required for Gemini provider"
                                             IsEnabled="{Binding IsApiKeyInputEnabled}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Single Word Lookup" Style="{StaticResource SettingsGroupBoxStyle}">
                            <StackPanel Margin="12,4">
                                <CheckBox Content="Show pronunciation" 
                                          IsChecked="{Binding ShowPronunciation}"
                                          Style="{StaticResource SettingsCheckBoxStyle}"
                                          Margin="0,4"/>
                                <TextBlock Text="Show phonetics and speaker button in the main translation popup for single words."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- About Section -->
                    <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=About}">
                         <GroupBox Header="About" Style="{StaticResource SettingsGroupBoxStyle}">
                            <StackPanel Margin="12,8">
                                <TextBlock Text="QuickTranslate v1.0.0" 
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="A fast, lightweight translation tool." 
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button Content="Save" 
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsDirty}"
                            MinWidth="70"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Foreground="White">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource WindowHeaderButtonStyle}">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="Background" Value="#555555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Close" 
                            Command="{Binding CloseCommand}"
                            MinWidth="70"
                            Padding="12,6"
                            Style="{StaticResource WindowHeaderButtonStyle}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
